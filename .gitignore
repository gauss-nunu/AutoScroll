# Gradle files
.gradle/

# Generated files, including most of the build folder
/build/
!/app/build/
/app/build/generated/
/app/build/intermediates/
/app/build/kotlin/
/app/build/outputs/blame/
/app/build/outputs/logs/
!/app/build/outputs/apk/
/app/build/outputs/apk/release/
!/app/build/outputs/apk/debug/
!/app/build/outputs/apk/debug/app-debug.apk
/app/build/tmp/

# Local configuration file (sdk path, etc)
local.properties

# Log Files
*.log

# Android Studio generated files
# *.apk  <- This is handled above
*.ap_
*.aab
*.dex
*.class

# Android Studio cache files
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries/
.idea/libraries/

# Keystore files
*.jks
*.keystore

# External native build folder created in Android Studio 2.2 and later
.externalNativeBuild/

# Google Services (e.g., Firebase)
google-services.json

# IntelliJ
*.iml
.idea/

# Mac
.DS_Store
